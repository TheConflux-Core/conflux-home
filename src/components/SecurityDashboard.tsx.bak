    padding: '20px',
  },
  promptTop: {
    display: 'flex',
    alignItems: 'center',
    gap: '12px',
    marginBottom: '12px',
  },
  promptAgentEmoji: {
    fontSize: '28px',
  },
  promptAgentInfo: {
    flex: 1,
  },
  promptAgentName: {
    fontSize: '16px',
    fontWeight: 700,
    color: '#f1f5f9',
    display: 'block',
  },
  promptAgentId: {
    fontSize: '11px',
    color: '#475569',
  },
  promptAge: {
    fontSize: '12px',
    color: '#475569',
  },
  promptRequest: {
    display: 'flex',
    alignItems: 'center',
    gap: '6px',
    marginBottom: '6px',
    fontSize: '14px',
  },
  promptRequestLabel: {
    color: '#94a3b8',
  },
  promptTool: {
    background: '#1e293b',
    color: '#22c55e',
    padding: '2px 8px',
    borderRadius: '4px',
    fontSize: '13px',
    fontFamily: 'monospace',
  },
  promptTarget: {
    fontSize: '13px',
    color: '#cbd5e1',
    background: '#020617',
    borderRadius: '6px',
    padding: '8px 12px',
    marginBottom: '14px',
    wordBreak: 'break-all' as const,
    fontFamily: 'monospace',
  },
  promptActions: {
    display: 'flex',
    gap: '8px',
    flexWrap: 'wrap' as const,
  },
  promptBtn: {
    padding: '7px 16px',
    border: 'none',
    borderRadius: '7px',
    color: 'white',
    cursor: 'pointer',
    fontSize: '13px',
    fontWeight: 600,
    transition: 'opacity 0.15s',
  },

  // Empty State
  emptyState: {
    textAlign: 'center' as const,
    padding: '48px 24px',
  },
  emptyIcon: {
    fontSize: '56px',
    marginBottom: '16px',
  },
  emptyTitle: {
    fontSize: '18px',
    fontWeight: 700,
    color: '#f1f5f9',
    marginBottom: '8px',
  },
  emptyText: {
    fontSize: '14px',
    color: '#64748b',
    maxWidth: '400px',
    margin: '0 auto',
    lineHeight: 1.6,
  },

  // Toast Notifications
  toast: {
    position: 'fixed' as const,
    top: 24,
    right: 24,
    zIndex: 9999,
    width: 340,
    background: 'linear-gradient(135deg, #1e293b, #0f172a)',
    border: '1px solid #22c55e55',
    borderRadius: 14,
    padding: '16px 18px',
    boxShadow: '0 8px 32px rgba(34, 197, 94, 0.25), 0 0 0 1px rgba(34, 197, 94, 0.1)',
    animation: 'slideInRight 0.3s ease',
  },
  toastTitle: {
    fontSize: '15px',
    fontWeight: 700,
    color: '#22c55e',
    marginBottom: 6,
  },
  toastBody: {
    fontSize: '13px',
    color: '#94a3b8',
    marginBottom: 12,
    lineHeight: 1.5,
  },
  toastActions: {
    display: 'flex',
    gap: 8,
  },
  toastBtn: {
    flex: 1,
    padding: '7px 0',
    border: 'none',
    borderRadius: 7,
    color: 'white',
    cursor: 'pointer',
    fontSize: '13px',
    fontWeight: 600,
    transition: 'opacity 0.15s',
  },

  // Error State
  errorBox: {
    display: 'flex',
    flexDirection: 'column' as const,
    alignItems: 'center',
    justifyContent: 'center',
    padding: '48px 24px',
    textAlign: 'center' as const,
    gap: '12px',
  },
  errorIcon: { fontSize: '52px' },
  errorTitle: { fontSize: '18px', fontWeight: 700, color: '#f1f5f9', margin: 0 },
  errorText: { fontSize: '14px', color: '#f59e0b', margin: 0, maxWidth: '400px' },
  errorHint: { fontSize: '13px', color: '#64748b', margin: 0 },
  retryBtn: {
    marginTop: '8px',
    padding: '9px 20px',
    background: '#1e293b',
    border: '1px solid #334155',
    borderRadius: '8px',
    color: '#e2e8f0',
    cursor: 'pointer',
    fontSize: '14px',
    fontWeight: 600,
  },
};
