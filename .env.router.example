# Conflux Router — API Keys
# Copy this file to .env.router and fill in your real keys.
# NEVER commit .env.router to git!

# Google AI Studio
CONFLUX_GOOGLE_API_KEY=your-google-ai-api-key

# Groq
CONFLUX_GROQ_API_KEY=your-groq-api-key

# Mistral
CONFLUX_MISTRAL_API_KEY=your-mistral-api-key

# DeepSeek
CONFLUX_DEEPSEEK_API_KEY=your-deepseek-api-key

# Cerebras
CONFLUX_CEREBRAS_API_KEY=your-cerebras-api-key

# Cloudflare Workers AI
CONFLUX_CLOUDFLARE_API_KEY=your-cloudflare-api-key
CONFLUX_CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
